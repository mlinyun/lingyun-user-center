{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 120,
  "tabWidth": 4,
  "useTabs": false,
  "semi": true,
  "singleQuote": false,
  "trailingComma": "es5",
  "bracketSpacing": true,
  "arrowParens": "always",
  "endOfLine": "lf",
  "bracketSameLine": false,
  "overrides": [
    {
      "files": ["*.md", "*.mdx"],
      "options": {
        "proseWrap": "preserve",
        "printWidth": 120,
        "tabWidth": 2
      }
    },
    {
      "files": ["*.json", "*.html"],
      "options": {
        "tabWidth": 2
      }
    }
  ],
  "ignorePatterns": [
    "**/node_modules/**",
    "**/dist/**",
    "**/build/**",
    "./pnpm-lock.yaml",
    "./.eslintcache",
    "./.eslintrc-auto-import.json",
    "./src/types/import/auto-imports.d.ts",
    "./src/types/import/components.d.ts"
  ]
}
