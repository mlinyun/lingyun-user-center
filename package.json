{
  "name": "lingyun-user-center",
  "version": "1.0.0",
  "description": "Enterprise user center with login, registration, profile management.",
  "keywords": [
    "user center",
    "authentication",
    "profile management"
  ],
  "author": "mlinyun <lingyun2311@gmail.com>",
  "type": "module",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": "^22.12.0 || ^24.12.0"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.0.9",
      "onFail": "download"
    }
  },
  "scripts": {
    "test": "echo \"Error: no test specified\"",
    "prepare": "husky",
    "lint-staged": "lint-staged",
    "commit": "cz",
    "commitlint": "commitlint --edit",
    "backend:check": "bash ./scripts/backend-pre-commit-check.sh",
    "backend:check:staged": "pnpm backend:check -- staged",
    "backend:check:full": "pnpm backend:check -- full"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.0",
    "@commitlint/config-conventional": "^21.0.0",
    "@commitlint/types": "^21.0.0",
    "@types/node": "^25.6.2",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "typescript": "^6.0.3"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}
